{
  "name": "lumea-solver",
  "version": "0.0.1",
  "description": "Lumea Solver - FastAPI service with OR-Tools constraint satisfaction",
  "scripts": {
    "dev": "uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "start": "uvicorn main:app --host 0.0.0.0 --port 8000",
    "test": "python -m pytest -v",
    "test:coverage": "python -m pytest --cov=. --cov-report=html",
    "lint": "ruff check . && black --check .",
    "lint:fix": "black . && ruff check . --fix",
    "format": "black .",
    "install": "pip install -r requirements.txt",
    "install:dev": "pip install -r requirements.txt && pip install pytest-cov",
    "typecheck": "python typecheck.py",
    "clean": "find . -type d -name '__pycache__' -exec rm -rf {} + && find . -name '*.pyc' -delete"
  },
  "keywords": ["fastapi", "ortools", "constraint-satisfaction", "interior-design", "layout-optimization"],
  "author": "Lumea Team",
  "license": "MIT"
}