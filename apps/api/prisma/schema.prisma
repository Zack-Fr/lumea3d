// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums aligned with shared schemas
enum Role {
  GUEST
  CLIENT
  DESIGNER
  ADMIN
}

enum StyleKey {
  MODERN
  CLASSIC
}

enum AssetKey {
  SOFA
  COFFEE_TABLE
  SIDE_TABLE
}

enum GenerationStatus {
  OK
  FALLBACK
  ERROR
}

// 3D Asset processing status
enum AssetStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

// 3D Asset license types
enum AssetLicense {
  CC0
  ROYALTY_FREE
  PROPRIETARY
}

// Core user management
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName String?  @map("display_name")
  role         Role     @default(DESIGNER)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // User relationships
  projects     Project[]
  feedback     Feedback[]
  sessions     Session[]
  invites      Invite[]
  assets       Asset[]

  @@map("users")
}

// Project management
model Project {
  id         String   @id @default(cuid())
  name       String
  user_id    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relationships
  user         User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  scenes       Scene[]
  categories3d ProjectCategory3D[]
  scenes3d     Scene3D[]

  // Indexes
  @@index([user_id])
  @@map("projects")
}

// Scene management - immutable snapshots
model Scene {
  id         String           @id @default(cuid())
  project_id String
  version    Int              @default(1)
  room_w_cm  Int              @default(500)
  room_h_cm  Int              @default(400)
  style      StyleKey         @default(MODERN)
  seed       Int?
  solver_ms  Int?
  status     GenerationStatus @default(OK)
  created_at DateTime         @default(now())

  // Relationships
  project            Project             @relation(fields: [project_id], references: [id], onDelete: Cascade)
  placements         Placement[]
  compliance_checks  ComplianceCheck[]
  feedback           Feedback[]
  placement_adjustments PlacementAdjustment[]

  // Rationale JSON storage
  rationale Json?

  // Indexes
  @@index([project_id])
  @@index([created_at])
  @@map("scenes")
}

// Asset placements in scenes
model Placement {
  id           String   @id @default(cuid())
  scene_id     String
  asset_key    AssetKey
  x_cm         Int
  y_cm         Int
  rotation_deg Int      @default(0)
  created_at   DateTime @default(now())

  // Relationships
  scene                 Scene                 @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  placement_adjustments PlacementAdjustment[]

  // Indexes
  @@index([scene_id])
  @@map("placements")
}

// Rule compliance tracking
model ComplianceCheck {
  id       String  @id @default(cuid())
  scene_id String
  rule_key String
  passed   Boolean
  message  String

  // Relationships
  scene Scene @relation(fields: [scene_id], references: [id], onDelete: Cascade)

  // Indexes
  @@index([scene_id])
  @@index([rule_key])
  @@map("compliance_checks")
}

// User feedback on scenes
model Feedback {
  id         String   @id @default(cuid())
  scene_id   String
  user_id    String
  rating     Int      // 1-5 scale
  tags       String[] // Array of string tags
  comment    String?
  is_private Boolean  @default(false)
  created_at DateTime @default(now())

  // Relationships
  scene Scene @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Indexes
  @@index([scene_id])
  @@index([user_id])
  @@index([rating])
  @@map("feedback")
}

// Collaboration sessions
model Session {
  id         String    @id @default(cuid())
  project_id String
  user_id    String
  token      String    @unique
  expires_at DateTime?
  created_at DateTime  @default(now())

  // Relationships
  user    User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  invites Invite[]

  // Indexes
  @@index([token])
  @@index([user_id])
  @@map("sessions")
}

// Session invitations
model Invite {
  id         String    @id @default(cuid())
  session_id String
  user_id    String
  token      String    @unique
  expires_at DateTime?
  used_at    DateTime?
  created_at DateTime  @default(now())

  // Relationships
  session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Indexes
  @@index([token])
  @@index([session_id])
  @@map("invites")
}

// Manual placement adjustments (post-generation nudging)
model PlacementAdjustment {
  id           String   @id @default(cuid())
  scene_id     String
  placement_id String
  old_x_cm     Int
  old_y_cm     Int
  new_x_cm     Int
  new_y_cm     Int
  old_rotation Int
  new_rotation Int
  created_at   DateTime @default(now())

  // Relationships
  scene     Scene     @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  placement Placement @relation(fields: [placement_id], references: [id], onDelete: Cascade)

  // Indexes
  @@index([scene_id])
  @@index([placement_id])
  @@map("placement_adjustments")
}

// ============================================================================
// 3D MODELS - New modular viewer system (side-by-side with 2D models above)
// ============================================================================

// 3D Asset management - uploaded GLB files with processing pipeline
model Asset {
  id           String      @id @default(cuid())
  uploader_id  String
  original_name String
  mime_type    String
  file_size    Int
  status       AssetStatus @default(UPLOADED)
  
  // Processing results
  original_url  String?
  meshopt_url   String?
  draco_url     String?
  navmesh_url   String?
  report_json   Json?
  error_message String?
  
  // Metadata
  license      AssetLicense? @default(PROPRIETARY)
  created_at   DateTime      @default(now()) @map("created_at")
  updated_at   DateTime      @updatedAt @map("updated_at")
  processed_at DateTime?     @map("processed_at")

  // Relationships
  uploader    User                @relation(fields: [uploader_id], references: [id], onDelete: Cascade)
  categories  ProjectCategory3D[]
  navmesh_scenes Scene3D[]

  // Indexes
  @@index([uploader_id])
  @@index([status])
  @@index([created_at])
  @@map("assets")
}

// 3D Categories per project - link assets to projects with category metadata
model ProjectCategory3D {
  id          String  @id @default(cuid())
  project_id  String
  asset_id    String
  category_key String // e.g., "furniture", "decor", "lighting"
  
  // Category configuration flags
  instancing  Boolean @default(false)
  draco       Boolean @default(true)
  meshopt     Boolean @default(true)
  ktx2        Boolean @default(true)
  
  created_at  DateTime @default(now()) @map("created_at")

  // Relationships
  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [asset_id], references: [id], onDelete: Cascade)
  
  // A project can have each asset only once per category
  @@unique([project_id, asset_id, category_key])
  @@index([project_id])
  @@index([category_key])
  @@map("project_categories_3d")
}

// 3D Scene management with version tracking for realtime deltas
model Scene3D {
  id          String  @id @default(cuid())
  project_id  String
  name        String
  version     Int     @default(1) // For optimistic locking and realtime deltas
  
  // Scene properties (matches SceneManifestV2)
  scale       Float?  @default(1.0)
  exposure    Float?  @default(1.0)
  env_hdri_url String?
  env_intensity Float? @default(1.0)
  
  // Spawn point
  spawn_position_x Float   @default(0.0)
  spawn_position_y Float   @default(1.7) // Eye level
  spawn_position_z Float   @default(5.0)
  spawn_yaw_deg    Float   @default(0.0)
  
  // Navmesh reference
  navmesh_asset_id String?
  
  created_at  DateTime @default(now()) @map("created_at")
  updated_at  DateTime @updatedAt @map("updated_at")

  // Relationships
  project      Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  navmesh_asset Asset?       @relation(fields: [navmesh_asset_id], references: [id], onDelete: SetNull)
  items        SceneItem3D[]

  // Indexes
  @@index([project_id])
  @@index([created_at])
  @@index([version])
  @@map("scenes_3d")
}

// 3D Scene items - positioned/scaled/rotated objects in scenes
model SceneItem3D {
  id          String @id @default(cuid())
  scene_id    String
  category_key String // References ProjectCategory3D.category_key
  model       String? // Optional model identifier within category
  
  // Transform (matches SceneManifestV2 item.transform)
  position_x     Float @default(0.0)
  position_y     Float @default(0.0)
  position_z     Float @default(0.0)
  rotation_x     Float @default(0.0) // Euler angles
  rotation_y     Float @default(0.0)
  rotation_z     Float @default(0.0)
  scale_x        Float @default(1.0)
  scale_y        Float @default(1.0)
  scale_z        Float @default(1.0)
  
  // Material configuration
  material_variant   String?
  material_overrides Json?
  
  // Item behavior
  selectable Boolean @default(true)
  locked     Boolean @default(false)
  
  // Metadata
  meta       Json?
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  // Relationships
  scene Scene3D @relation(fields: [scene_id], references: [id], onDelete: Cascade)

  // Indexes
  @@index([scene_id])
  @@index([category_key])
  @@map("scene_items_3d")
}