# Storage Configuration for Hunyuan3D Service
# Copy this file to .env and update with your actual values

# Storage Provider (minio or s3)
STORAGE_PROVIDER=minio

# MinIO/S3 Configuration
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=your-access-key-here
STORAGE_SECRET_KEY=your-secret-key-here
STORAGE_REGION=us-east-1

# Bucket Configuration
STORAGE_BUCKET=lumea-generations
STORAGE_BUCKET_PRIVATE=true

# Path Configuration
STORAGE_BASE_PATH=gen
STORAGE_PRESIGNED_EXPIRY=900

# Local Fallback (for development)
STORAGE_LOCAL_FALLBACK=true
STORAGE_LOCAL_PATH=./outputs

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here

# Service Configuration
PORT=8001
LOG_LEVEL=info